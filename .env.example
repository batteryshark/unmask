# unmask configuration — copy to `.env` and fill in.  `.env` is gitignored.
#
# unmask's deterministic scan needs NONE of this. These variables only configure the
# optional agentic review overlay (`unmask run --review`), which adjudicates findings
# with an LLM. Pick ONE stanza below, uncomment it, and fill in the key.
#
# Resolution order for every field: real exported env var > .env > provider preset.

# ── Provider preset ──────────────────────────────────────────────────────────
# UNMASK_REVIEW_PROVIDER picks a preset that fills in base_url + wire protocol:
#   lmstudio   local, OpenAI-wire   (http://localhost:1234/v1)
#   openai     OpenAI               (https://api.openai.com/v1)
#   anthropic  Anthropic            (https://api.anthropic.com)
#   minimax    MiniMax, Anthropic-wire (https://api.minimax.io/anthropic)
#   zai        z.ai GLM, OpenAI-wire   (https://api.z.ai/api/paas/v4)
#   custom     you set BASE_URL + KIND yourself (any OpenAI/Anthropic-compatible server)
#
# UNMASK_REVIEW_MODEL   the model id (required)
# UNMASK_REVIEW_BASE_URL overrides the preset's endpoint
# UNMASK_REVIEW_API_KEY  the key (or set the preset's own key var, e.g. OPENAI_API_KEY)
# UNMASK_REVIEW_KIND     wire protocol: openai | anthropic (only needed for `custom`)

# ── Example: OpenAI ──────────────────────────────────────────────────────────
# UNMASK_REVIEW_PROVIDER=openai
# UNMASK_REVIEW_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# ── Example: a local model (LM Studio / llama.cpp / MLX, OpenAI-compatible) ───
# UNMASK_REVIEW_PROVIDER=lmstudio
# UNMASK_REVIEW_MODEL=qwen2.5-coder-32b
# UNMASK_REVIEW_BASE_URL=http://127.0.0.1:1234/v1
# UNMASK_REVIEW_API_KEY=not-needed

# ── Example: a custom Anthropic-compatible endpoint ──────────────────────────
# UNMASK_REVIEW_PROVIDER=custom
# UNMASK_REVIEW_MODEL=your-model-id
# UNMASK_REVIEW_BASE_URL=http://127.0.0.1:1357
# UNMASK_REVIEW_KIND=anthropic
# UNMASK_REVIEW_API_KEY=not-needed

# ── Per-role overrides (optional) ────────────────────────────────────────────
# Use a cheaper model for lead-proposal and a stronger one for verification:
#   unmask run --review --models proposer=lmstudio:small,verifier=openai:gpt-4o
