[
  {
    "id": "CAP-EXEC",
    "label": "Command / process execution",
    "atoms": [
      "EXEC.SHELL",
      "EXEC.PROC",
      "EXEC.INJECT",
      "EXEC.TERMINATE",
      "EXEC.SYSCALL"
    ],
    "severity": "high",
    "reach": "run shell commands or spawn processes",
    "guardrails": [
      "Sandbox execution",
      "Remove process-spawn ability",
      "Allowlist permitted commands"
    ]
  },
  {
    "id": "CAP-BROWSER",
    "label": "Browser automation",
    "atoms": [
      "EXEC.BROWSER"
    ],
    "severity": "high",
    "reach": "drive a real browser: navigate, scrape, fill and submit forms, run page scripts, and reach authenticated sessions",
    "guardrails": [
      "Run headless with a throwaway profile",
      "Allowlist navigable origins",
      "Never attach to the user's real browser profile or cookies"
    ]
  },
  {
    "id": "CAP-DYNLOAD",
    "label": "Dynamic code loading",
    "atoms": [
      "LOAD"
    ],
    "severity": "high",
    "reach": "load and run code chosen at runtime",
    "guardrails": [
      "Disable eval / dynamic import",
      "Pin loadable modules to an allowlist"
    ]
  },
  {
    "id": "CAP-CRED",
    "label": "Credential access",
    "atoms": [
      "CRED"
    ],
    "severity": "high",
    "reach": "read credential or secret material",
    "guardrails": [
      "Scope secrets to least privilege",
      "Rotate exposed secrets",
      "Avoid env-var secrets"
    ]
  },
  {
    "id": "CAP-PRIV",
    "label": "Privilege operations",
    "atoms": [
      "PRIV"
    ],
    "severity": "high",
    "reach": "request, assume, or exploit elevated privilege",
    "guardrails": [
      "Drop privileges",
      "Run with least authority"
    ]
  },
  {
    "id": "CAP-PERSIST",
    "label": "Persistence",
    "atoms": [
      "PRST"
    ],
    "severity": "high",
    "reach": "survive process exit, reboot, or session boundaries",
    "guardrails": [
      "Remove persistence hooks",
      "Monitor autostart locations"
    ]
  },
  {
    "id": "CAP-NET",
    "label": "Outbound network reach",
    "atoms": [
      "NETW.HTTP",
      "NETW.FTP",
      "NETW.SOCKET",
      "NETW.WEBHOOK",
      "NETW.WS",
      "NETW.DNS",
      "NETW.EMAIL",
