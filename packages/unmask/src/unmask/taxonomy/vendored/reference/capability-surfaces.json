      "NETW.LISTEN",
      "NETW.SSE",
      "NETW.DECENTRAL"
    ],
    "severity": "medium",
    "reach": "send and receive data over the network",
    "guardrails": [
      "Egress allowlist",
      "Pin destinations",
      "Block network at install time"
    ]
  },
  {
    "id": "CAP-FS-WRITE",
    "label": "Filesystem mutation",
    "atoms": [
      "FSYS.WRITE",
      "FSYS.DELETE",
      "FSYS.PERM",
      "FSYS.LINK"
    ],
    "severity": "medium",
    "reach": "create, modify, or delete files",
    "guardrails": [
      "Restrict writable paths",
      "Mount the filesystem read-only where possible"
    ]
  },
  {
    "id": "CAP-INSTALL",
    "label": "Unsupervised install-time execution",
    "atoms": [
      "PKGM.INSTALL",
      "PKGM.HOOK",
      "PKGM.BINDOWN"
    ],
    "severity": "medium",
    "reach": "execute code at install time, before any explicit use",
    "guardrails": [
      "Install with --ignore-scripts",
      "Review and vendor the dependency",
      "Pin and checksum downloaded binaries"
    ]
  },
  {
    "id": "CAP-AGENT",
    "label": "Agent-directed content surface",
    "atoms": [
      "AITM"
    ],
    "severity": "medium",
    "reach": "shape what an AI agent reads, believes, or does",
    "guardrails": [
      "Treat as untrusted input to agents",
      "Strip / sanitize agent-directed content"
    ]
  },
  {
