    ]
  },
  {
    "id": "CAP-RSRC",
    "label": "Resource consumption",
    "atoms": [
      "RSRC"
    ],
    "severity": "low",
    "reach": "consume CPU, memory, disk, or network capacity",
    "guardrails": [
