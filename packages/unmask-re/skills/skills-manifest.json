{
  "schemaVersion": "0.1.0",
  "sourceRoot": "/Users/batteryshark/Downloads/runner-lab/rekit",
  "skills": [
    {
      "id": "unpack",
      "name": "Archive Unpacker (recursive, safe)",
      "version": "0.1.0",
      "capabilities": [
        "unpack-archive",
        "extract-recursive"
      ],
      "prerequisites": [
        {
          "tool": "python3",
          "min_version": "3.8",
          "check": [
            "python3",
            "--version"
          ],
          "install_hint": "Install Python 3.8+ (3.12+ enables tarfile's safe 'data' filter). Pure stdlib for zip/tar/gz/bz2/xz."
        }
      ],
      "entry": {
        "command": [
          "python3",
          "runtime/unpack.py"
        ],
        "args": [
          {
            "name": "input",
            "type": "file",
            "required": true,
            "desc": "archive to extract"
          },
          {
            "name": "outdir",
            "type": "dir",
            "required": true,
            "desc": "output directory"
          },
          {
            "name": "--max-depth",
            "type": "int",
            "required": false,
            "desc": "nested-archive recursion depth (default 8)"
          },
          {
            "name": "--max-bytes",
            "type": "int",
            "required": false,
            "desc": "total extracted-bytes budget (default 512 MiB)"
          }
        ],
        "result": {
          "channel": "stdout",
          "format": "json",
          "fields": {
            "ok": "bool",
            "format": "string",
            "extractedTo": "string",
            "fileCount": "int",
            "nestedArchives": "array",
            "skipped": "array",
            "toolsMissing": "array"
          }
        }
      },
      "sha256": "f0fb8f9b3c6af89ceccb2194ab4788b798cadc229766960801272b4796b0dee1"
    },
    {
      "id": "bin-triage",
      "name": "Binary Triage (format-agnostic)",
      "version": "0.1.0",
      "capabilities": [
        "triage-binary",
        "identify-format",
        "extract-strings",
        "detect-embedded",
        "carve-embedded",
        "emit-atoms"
      ],
      "prerequisites": [
        {
          "tool": "python3",
          "min_version": "3.8",
          "check": [
            "python3",
            "--version"
          ],
          "install_hint": "Install Python 3.8+ \u2014 pure stdlib, no other dependency."
        }
      ],
      "entry": {
        "command": [
          "python3",
          "runtime/triage.py"
        ],
        "args": [
          {
            "name": "input",
            "type": "file",
            "required": true,
            "desc": "any file to triage"
          },
          {
            "name": "outdir",
            "type": "dir",
            "required": false,
            "desc": "if given, carve embedded readable-source regions here for rescanning"
          },
          {
            "name": "--format",
            "type": "enum",
            "required": false,
            "desc": "text | json (default text)",
            "choices": [
              "text",
              "json"
            ]
          },
          {
            "name": "--max-bytes",
            "type": "int",
            "required": false,
            "desc": "atom-analysis read cap (default 64 MiB; carving always scans the whole file)"
          }
        ],
        "result": {
          "channel": "stdout",
          "format": "text|json",
          "fields": {
            "ok": "bool",
            "size": "int",
            "formats": "array",
            "entropyFirstMiB": "number",
            "interestingStrings": "object",
            "embeddedSignatures": "array",
            "atoms": "array",
            "carved": "array",
            "outputDir": "string"
          }
        }
      },
      "sha256": "badee035aadadcb479a8a900e967713bb960d227a752f67870ce8b712dec0867"
    },
    {
      "id": "js-deobfuscate",
      "name": "JavaScript Deobfuscator",
      "version": "0.1.0",
      "capabilities": [
        "deobfuscate-js",
        "unpack-js-bundle",
        "unminify-js"
      ],
      "prerequisites": [
        {
          "tool": "node",
          "min_version": "18",
          "check": [
            "node",
            "--version"
          ],
          "install_hint": "Install Node.js >= 18 (an LTS is safest for the isolated-vm prebuilt ABI). The tool is vendored; no npm/network is needed at run time."
        }
      ],
      "entry": {
        "command": [
          "node",
          "runtime/run.mjs"
        ],
        "args": [
          {
            "name": "input",
            "type": "file",
            "required": true,
            "desc": "path to the obfuscated .js"
          },
          {
            "name": "outdir",
            "type": "dir",
            "required": true,
            "desc": "output dir; writes deobfuscated.js and, for bundles, unpacked/ modules"
          }
        ],
        "result": {
          "channel": "stdout",
          "format": "json",
          "fields": {
            "ok": "bool",
            "outputFile": "string",
            "unpackedDir": "string|null",
            "moduleCount": "int",
            "bytesIn": "int",
            "bytesOut": "int",
            "changed": "bool"
          }
        }
      },
      "sha256": "183b3ffbd404f7e17e25f118d46a38550238226390692d08871f51e32ea3a23e"
    },
